# Copy to .env and fill in real values. Never commit .env.

# Postgres
DB_URL=jdbc:postgresql://localhost:5432/zephyr_capital
DB_USERNAME=postgres
DB_PASSWORD=
DB_HOST=localhost

# Spring
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
APP_DOMAIN=localhost

# External APIs
OPENAI_API_KEY=
ALPHAVANTAGE_API_KEY=
RECAPTCHA_SECRET=

# Encryption key used by EncryptionUtil (32-char AES key)
ENCRYPTION_SECRET_KEY=

# HMAC-SHA secret for signing JWT auth tokens (64 hex chars recommended)
JWT_SECRET_KEY=

# SMTP (Gmail app password)
MAIL_USERNAME=
MAIL_PASSWORD=

# TradeStation OAuth (per-user)
TS_JOHN_CLIENT_ID=
TS_JOHN_CLIENT_SECRET=
TS_JOHN_REFRESH_TOKEN=
TS_KAIDEN_CLIENT_ID=
TS_KAIDEN_CLIENT_SECRET=
TS_KAIDEN_REFRESH_TOKEN=
TS_ACCESS_TOKEN=
