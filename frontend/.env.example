# Copy to .env and fill in values. Never commit .env.
# NOTE: REACT_APP_* values are inlined into the client bundle at build time
# and visible to anyone visiting the deployed site. Do not put true secrets here.

REACT_APP_API_URL=http://localhost:8080
REACT_APP_SECRET_KEY=
REACT_APP_OPENAI_API_KEY=
REACT_APP_ALPHAVANTAGE_KEY=
REACT_APP_FEEDBACK_EMAIL=feedback@example.com
REACT_APP_RECAPTCHA_SITE_KEY=

